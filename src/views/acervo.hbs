<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#6d1623" />
    <title>{{pageTitle}}</title>
    <link rel="manifest" href="/public/manifest.webmanifest" />
    <link rel="icon" href="/public/icons/icon-192.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.2/css/bulma.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/public/css/app.css" />
  </head>
  <body>
    <nav class="navbar is-light" role="navigation" aria-label="Navegacao principal">
      <div class="container">
        <div class="navbar-brand">
          <a class="navbar-item has-text-weight-semibold" href="/#home" aria-label="Ir para o inicio">
            Museu do Vinho
          </a>
        </div>
        <div class="navbar-menu is-active">
          <div class="navbar-end">
            <a class="navbar-item" href="/#home">
              <span class="icon-text">
                <span class="icon">
                  <i class="fa-solid fa-house" aria-hidden="true"></i>
                </span>
                <span>Início</span>
              </span>
            </a>
            <a class="navbar-item" href="/#institucional">Sobre</a>
            <a class="navbar-item is-active" href="/acervo">Acervo</a>
            <a class="navbar-item" href="/#timeline">Linha do tempo</a>
            <a class="navbar-item" href="/#contato-link">Contato</a>
          </div>
        </div>
      </div>
    </nav>

    <header class="hero is-small is-dark">
      <div class="hero-body py-6">
        <div class="container">
          <h1 class="title is-2 has-text-white">Explorar o Acervo</h1>
          <p class="subtitle is-5 has-text-grey-light">
            Filtros iniciais para navegacao por categorias do acervo digital.
          </p>
        </div>
      </div>
    </header>

    <main class="section has-background-light">
      <div class="container">
        <div class="buttons mb-5">
          {{#each categories}}
          <a
            href="/acervo?categoria={{this.slug}}"
            class="button is-rounded {{#if this.isActive}}is-dark{{else}}is-light{{/if}}"
          >
            {{this.label}} ({{this.count}})
          </a>
          {{/each}}
        </div>

        <p class="is-size-7 has-text-grey mb-4">
          Exibindo {{pagination.totalItems}} itens no total. Pagina {{pagination.currentPage}} de
          {{pagination.totalPages}}.
        </p>

        {{#if hasItems}}
        <div class="columns is-multiline">
          {{#each items}}
          <div class="column is-4-desktop is-6-tablet">
            <article class="card h-100" aria-label="Item do acervo: {{this.description}}">
              <div class="card-image">
                <figure class="image is-square has-background-grey-lighter">
                  <img src="{{this.imageUrl}}" alt="{{this.description}}" loading="lazy" />
                </figure>
              </div>

              <div class="card-content">
                <div class="tags mb-3">
                  {{#if this.estimatedYear}}
                  <span class="tag is-warning is-light">Ano estimado: {{this.estimatedYear}}</span>
                  {{/if}} {{#if this.historicalPeriod}}
                  <span class="tag is-light">{{this.historicalPeriod}}</span>
                  {{/if}}
                </div>

                <p class="mb-4">{{this.description}}</p>

                <div class="tags">
                  {{#each this.categoriesLabel}}
                  <span class="tag is-info is-light">{{this}}</span>
                  {{/each}}
                </div>

                <p class="is-size-7 has-text-grey mt-2">Pessoas na cena: {{this.peopleCount}}</p>
                <p class="is-size-7 has-text-grey">Tipo: {{this.documentType}}</p>
                <p class="is-size-7 has-text-grey">Tags: {{this.tags}}</p>
              </div>

              <div class="card-footer">
                <p class="card-footer-item is-size-7 has-text-grey-light">
                  <span class="icon-text">
                    <span class="icon is-small"><i class="fa-solid fa-robot" aria-hidden="true"></i></span>
                    <span>Informacoes geradas por IA</span>
                  </span>
                </p>
              </div>
            </article>
          </div>
          {{/each}}
        </div>
        {{else}}
        <article class="message is-warning is-light">
          <div class="message-body">Nenhuma imagem encontrada para este filtro.</div>
        </article>
        {{/if}}

        <nav class="pagination is-centered mt-5" role="navigation" aria-label="Paginacao do acervo">
          {{#if pagination.hasPrevious}}
          <a class="pagination-previous" href="{{pagination.basePath}}{{pagination.previousPage}}">Anterior</a>
          {{else}}
          <a class="pagination-previous" disabled>Anterior</a>
          {{/if}} {{#if pagination.hasNext}}
          <a class="pagination-next" href="{{pagination.basePath}}{{pagination.nextPage}}">Proxima</a>
          {{else}}
          <a class="pagination-next" disabled>Proxima</a>
          {{/if}}
        </nav>

        <article class="message is-warning is-light mb-5" aria-label="Aviso sobre uso de IA">
          <div class="message-body">
            <p class="has-text-weight-semibold">
              <span class="icon-text">
                <span class="icon is-small"><i class="fa-solid fa-robot" aria-hidden="true"></i></span>
                <span>Metadados gerados por IA</span>
              </span>
            </p>
            <p class="is-size-7 mt-1">
              Descricoes, categorias, tags e demais informacoes deste acervo foram geradas automaticamente por
              inteligencia artificial e podem conter imprecisoes.
            </p>
          </div>
        </article>
      </div>
    </main>

    <footer class="footer">
      <div class="container">
        <div class="columns">
          <div class="column is-4">
            <h3 class="title is-5">Museu do Vinho · Videira</h3>
            <p>Preservando a memoria e a cultura da vitivinicultura catarinense desde 1984.</p>
          </div>
          <div class="column">
            <p class="has-text-weight-semibold mb-2">Navegacao</p>
            <p><a href="/#home">Pagina inicial</a></p>
            <p><a href="/#institucional">Sobre o museu</a></p>
            <p><a href="/acervo">Acervo</a></p>
          </div>
          <div class="column">
            <p class="has-text-weight-semibold mb-2">Visita</p>
            <p>Ter-Dom: 9h-17h</p>
            <p>Entrada gratuita</p>
            <p>Grupos: agendar</p>
          </div>
          <div class="column">
            <p class="has-text-weight-semibold mb-2">Contato</p>
            <p>Videira - SC</p>
            <p>museudovinho@videira.sc.gov.br</p>
            <p>(49) 9 9156-1089</p>
          </div>
        </div>
        <hr />
        <p class="is-size-7 has-text-centered">© {{year}} Museu do Vinho de Videira · Secretaria de Cultura</p>
      </div>
    </footer>

    <a
      class="button is-success is-rounded whatsapp-float"
      href="https://wa.me/5549991561089"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Falar no WhatsApp"
    >
      <span class="icon" aria-hidden="true"><i class="fa-brands fa-whatsapp"></i></span>
      <span>WhatsApp</span>
    </a>
    <script src="/public/js/main.js"></script>
  </body>
</html>
