{{#> base pageTitle=pageTitle year=year themeColor="#6d1623" isAcervo=true}}
<header class="hero is-small is-dark">
  <div class="hero-body py-6">
    <div class="container">
      <h1 class="title is-2 has-text-white">Explorar o Acervo</h1>
      <p class="subtitle is-5 has-text-grey-light">Filtros iniciais para navegacao por categorias do acervo digital.</p>
    </div>
  </div>
</header>

<main class="section has-background-light">
  <div class="container">
    <div class="buttons mb-5">
      {{#each categories}}
      <a
        href="/acervo?categoria={{this.slug}}"
        class="button is-rounded {{#if this.isActive}}is-dark{{else}}is-light{{/if}}"
      >
        {{this.label}} ({{this.count}})
      </a>
      {{/each}}
    </div>

    <div
      class="is-flex is-justify-content-space-between is-align-items-center mb-1 is-flex-wrap-wrap"
      style="gap: 0.75rem"
    >
      <p id="acervo-count-status" class="is-size-7 has-text-grey mb-0">Exibindo {{items.length}} itens.</p>

      <div class="buttons has-addons are-small mb-0" id="acervo-view-controls" aria-label="Modo de visualizacao">
        <button class="button is-dark" type="button" data-view-mode="cards" aria-pressed="true">Cards</button>
        <button class="button is-light" type="button" data-view-mode="list-compact" aria-pressed="false">
          Lista compacta
        </button>
        <button class="button is-light" type="button" data-view-mode="list-detailed" aria-pressed="false">
          Lista detalhada
        </button>
      </div>
    </div>

    {{#if hasItems}}
    <div
      id="acervo-grid"
      class="columns is-multiline acervo-grid acervo-grid--cards"
      data-category="{{activeCategory}}"
      data-page-size="24"
    >
      {{#each items}}
      <div class="column is-4-desktop is-6-tablet">
        <article class="card h-100" aria-label="Item do acervo: {{this.description}}">
          <div class="card-image">
            <figure class="image is-square has-background-grey-lighter">
              <img src="{{this.imageUrl}}" alt="{{this.description}}" loading="lazy" />
            </figure>
          </div>

          <div class="card-content">
            <div class="tags mb-3">
              {{#if this.estimatedYear}}
              <span class="tag is-warning is-light">Ano estimado: {{this.estimatedYear}}</span>
              {{/if}} {{#if this.historicalPeriod}}
              <span class="tag is-light">{{this.historicalPeriod}}</span>
              {{/if}}
            </div>

            <p class="mb-4 acervo-description">{{this.description}}</p>

            <div class="tags acervo-category-tags">
              {{#each this.categoriesLabel}}
              <span class="tag is-info is-light">{{this}}</span>
              {{/each}}
            </div>

            <p class="is-size-7 has-text-grey mt-2 acervo-meta-item">Pessoas na cena: {{this.peopleCount}}</p>
            <p class="is-size-7 has-text-grey acervo-meta-item">Tipo: {{this.documentType}}</p>
            <p class="is-size-7 has-text-grey acervo-meta-item">Tags: {{this.tags}}</p>
          </div>

          <div class="card-footer">
            <p class="card-footer-item is-size-7 has-text-grey-light">
              <span class="icon-text">
                <span class="icon is-small"><i class="fa-solid fa-robot" aria-hidden="true"></i></span>
                <span>Informacoes geradas por IA</span>
              </span>
            </p>
          </div>
        </article>
      </div>
      {{/each}}
    </div>

    <div id="acervo-loading" class="has-text-centered is-size-7 has-text-grey my-4 is-hidden">
      Carregando mais itens...
    </div>
    {{!--
    <div id="acervo-end-message" class="has-text-centered is-size-7 has-text-grey my-4 is-hidden">
      Voce chegou ao fim deste acervo.
    </div>
    --}}
    <div id="acervo-sentinel" class="acervo-sentinel" aria-hidden="true"></div>

    <noscript>
      <article class="message is-info is-light mt-4">
        <div class="message-body">Ative JavaScript para carregar o restante das imagens ao rolar a pagina.</div>
      </article>
    </noscript>
    {{else}}
    <article class="message is-warning is-light">
      <div class="message-body">Nenhuma imagem encontrada para este filtro.</div>
    </article>
    {{/if}}

    <article class="message is-warning is-light mb-5" aria-label="Aviso sobre uso de IA">
      <div class="message-body">
        <p class="has-text-weight-semibold">
          <span class="icon-text">
            <span class="icon is-small"><i class="fa-solid fa-robot" aria-hidden="true"></i></span>
            <span>Metadados gerados por IA</span>
          </span>
        </p>
        <p class="is-size-7 mt-1">
          Descricoes, categorias, tags e demais informacoes deste acervo foram geradas automaticamente por inteligencia
          artificial e podem conter imprecisoes.
        </p>
      </div>
    </article>
  </div>
</main>
{{/base}}
