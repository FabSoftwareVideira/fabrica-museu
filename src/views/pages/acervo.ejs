<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Pagina inicial da area de exploracao do acervo do Museu do Vinho."
    />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">Museu do Vinho</a>
        <nav aria-label="Navegacao principal">
          <a class="<%= activePage === 'home' ? 'active' : '' %>" href="/">Inicio</a>
          <a class="<%= activePage === 'acervo' ? 'active' : '' %>" href="/acervo">Explorar o Acervo</a>
        </nav>
        <button id="theme-toggle" class="theme-toggle" aria-label="Alternar modo escuro">
          Modo escuro
        </button>
      </div>
    </header>

    <main class="section">
      <div class="container">
        <h1>Explorar o Acervo</h1>
        <p>
          Esta pagina e o ponto de partida para a navegacao por categorias e filtros do acervo
          digital. Na proxima etapa, entraremos com dados e imagens reais.
        </p>
        <a class="text-link" href="/">Voltar para a pagina inicial</a>
      </div>
    </main>

    <script src="/js/app.js"></script>
  </body>
</html>
