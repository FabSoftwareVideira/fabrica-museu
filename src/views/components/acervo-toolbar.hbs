<section class="acervo-toolbar" aria-label="Filtros e visualização do acervo">
  <div class="acervo-toolbar-header">
    <div>
      <p class="acervo-toolbar-kicker">Filtros</p>
      <h2 class="acervo-toolbar-title">Categoria e Subcategoria</h2>
    </div>

    <button
      type="button"
      class="button is-white is-small acervo-toolbar-close"
      data-acervo-filters-toggle
      aria-controls="acervo-filters-sidebar"
      aria-expanded="true"
    >
      <span class="icon is-small"><i class="fa-solid fa-xmark"></i></span>
      <span>Fechar</span>
    </button>
  </div>

  <p id="acervo-count-status" class="is-size-7 has-text-grey mb-1">Exibindo {{items.length}} itens.</p>

  <div class="acervo-toolbar-row acervo-toolbar-row--search">
    <div class="field mb-0">
      <div class="control has-icons-right">
        <input
          id="acervo-description-filter"
          type="search"
          class="input is-small"
          placeholder="Filtrar por descrição..."
          aria-label="Filtrar itens por descrição"
          autocomplete="off"
        />
        <span class="icon is-small is-right" aria-hidden="true">
          <i class="fa-solid fa-magnifying-glass"></i>
        </span>
      </div>
    </div>
  </div>

  <div class="acervo-toolbar-row acervo-toolbar-row--categories">
    <p class="is-size-7 has-text-grey mb-2">Categoria temática</p>
    <div class="acervo-category-chips" role="list">
      {{#each categories}}
      <a
        href="{{this.href}}"
        class="button is-rounded is-small acervo-category-chip {{#if this.isActive}}is-dark{{else}}is-light{{/if}}"
        role="listitem"
      >
        <span>{{this.label}}</span>
        <span class="acervo-category-chip-count">{{this.count}}</span>
      </a>
      {{/each}}
    </div>
  </div>

  {{#if hasSubcategoryFilter}}
  <div class="acervo-toolbar-row acervo-toolbar-row--categories">
    <p class="is-size-7 has-text-grey mb-2">Subcategoria</p>
    <div class="acervo-category-chips" role="list">
      {{#each subcategories}}
      <a
        href="{{this.href}}"
        class="button is-rounded is-small acervo-category-chip {{#if this.isActive}}is-dark{{else}}is-light{{/if}}"
        role="listitem"
      >
        <span>{{this.label}}</span>
        <span class="acervo-category-chip-count">{{this.count}}</span>
      </a>
      {{/each}}
    </div>
  </div>
  {{else}}
  <div class="acervo-toolbar-row acervo-toolbar-row--categories">
    <p class="is-size-7 has-text-grey mb-0">
      Selecione uma categoria temática para habilitar o filtro de subcategoria.
    </p>
  </div>
  {{/if}}
</section>
