<section class="section has-background-light" id="timeline">
  <div class="container">
    <p class="is-size-7 has-text-weight-semibold has-text-grey mb-2">HISTÓRIA</p>
    <h2 class="title is-3">Uma linha do tempo da vitivinicultura</h2>
    <p class="mb-5">Da chegada dos imigrantes italianos ao reconhecimento do vinho catarinense.</p>

    <div class="columns is-multiline">
      <div class="column is-6-tablet is-3-desktop">
        <div class="box">
          <p class="tag is-dark mb-2">1875</p>
          <p>Chegada dos primeiros imigrantes italianos ao Vale do Rio do Peixe.</p>
        </div>
      </div>
      <div class="column is-6-tablet is-3-desktop">
        <div class="box">
          <p class="tag is-dark mb-2">1910</p>
          <p>Primeiros vinhedos comerciais instalados na região de Videira.</p>
        </div>
      </div>
      <div class="column is-6-tablet is-3-desktop">
        <div class="box timeline-highlight-card">
          <p class="tag timeline-highlight-year mb-2">1984</p>
          <p class="timeline-highlight-text">Fundação do Museu do Vinho de Videira.</p>
        </div>
      </div>
      <div class="column is-6-tablet is-3-desktop">
        <div class="box">
          <p class="tag is-dark mb-2">2003 e Hoje</p>
          <p>Expansão do espaço físico e consolidação como referência turística em SC.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section" id="contato-link">
  <div class="container">
    <div class="columns is-variable is-6">
      <div class="column is-5-desktop">
        <div class="box contact-panel">
          <p class="contact-panel__kicker">VENHA NOS VISITAR</p>
          <h2 class="title is-3 mb-2">Planeje sua visita ao Museu</h2>
          <p class="contact-panel__lead">
            Aberto de terça a domingo, com entrada gratuita para escolas e grupos agendados.
          </p>

          <div class="contact-info-list">
            <article class="contact-info-item">
              <span class="icon contact-info-item__icon" aria-hidden="true">
                <i class="fa-solid fa-location-dot"></i>
              </span>
              <div>
                <p class="contact-info-item__label">Endereço</p>
                <p class="contact-info-item__text">Rua Padre Anchieta n° 334, Matriz, Videira, SC</p>
              </div>
            </article>

            <article class="contact-info-item">
              <span class="icon contact-info-item__icon" aria-hidden="true">
                <i class="fa-solid fa-clock"></i>
              </span>
              <div>
                <p class="contact-info-item__label">Horários</p>
                <ul class="contact-hours-list">
                  <li><strong>Terça a Sexta:</strong> 08h00 - 12h00 | 13h00 - 17h00</li>
                  <li><strong>Sábado e Domingo:</strong> 14h00 - 17h30</li>
                  <li><strong>Segunda-feira:</strong> Fechado</li>
                </ul>
              </div>
            </article>

            <article class="contact-info-item">
              <span class="icon contact-info-item__icon" aria-hidden="true">
                <i class="fa-solid fa-address-book"></i>
              </span>
              <div>
                <p class="contact-info-item__label">Contato</p>
                <p class="contact-info-item__text">(49) 3566-6133</p>
                <p class="contact-info-item__text">museudovinho@videira.sc.gov.br</p>
              </div>
            </article>
          </div>

          <div class="buttons mt-5">
            <a
              class="button is-warning is-outlined"
              href="https://wa.me/5549991561089"
              target="_blank"
              rel="noopener noreferrer"
              ><span class="icon is-small"><i class="fa-brands fa-whatsapp"></i></span><span>Agendar visita</span></a
            >
            <a class="button is-light is-outlined" href="mailto:museudovinho@videira.sc.gov.br"
              ><span class="icon is-small"><i class="fa-solid fa-envelope"></i></span><span>Fale conosco</span></a
            >
          </div>
        </div>
      </div>

      <div class="column is-7-desktop">
        <div class="box contact-map-box">
          <div id="museum-map" class="contact-map" aria-label="Mapa com a localização do Museu do Vinho"></div>
        </div>
      </div>
    </div>
  </div>
</section>
