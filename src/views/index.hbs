{{#> base pageTitle=pageTitle year=year themeColor="#7b1c2e" isHome=true loadLeaflet=true}}
<section id="home" class="hero is-medium is-dark home-hero-highlight">
  <div class="hero-body">
    <div class="container">
      <p class="tag is-warning is-light mb-4">Videira - Santa Catarina - Est. 1984</p>
      <h1 class="title is-1">A memória viva do vinho catarinense</h1>
      <p class="subtitle is-5">
        Um espaço dedicado à história, cultura e tradição vinícola do Vale do Rio do Peixe. Descubra anos de imigração
        italiana e paixão pela viticultura.
      </p>
      <p class="hero-museum-signature">Museu do Vinho <span class="hero-museum-name">Mario de Pellegrin</span></p>
      <div class="buttons mt-5">
        <a href="/acervo" class="button is-medium has-text-weight-semibold acervo-cta-link">Explorar acervo</a>
        <a href="#destaques" class="button is-light is-medium">Ver destaques</a>
      </div>
    </div>
  </div>
</section>

<section class="section" id="institucional">
  <div class="container">
    <div class="columns is-vcentered is-variable is-6">
      <div class="column is-7-desktop">
        <p class="is-size-7 has-text-weight-semibold has-text-grey mb-2">O MUSEU</p>
        <h2 class="title is-2">Guardiões da cultura vinícola do Sul do Brasil</h2>
        <p>
          Fundado na cidade de Videira, o Museu do Vinho preserva e difunde o patrimônio histórico e cultural ligado à
          vitivinicultura regional.
        </p>
        <p class="mt-3">
          O acervo reúne ferramentas, documentos, fotografias e objetos que contam a saga dos colonizadores italianos na
          região.
        </p>
        <div class="columns is-mobile mt-4">
          <div class="column has-text-centered">
            <p class="title is-4 mb-1">2400+</p>
            <p class="is-size-7">Peças no acervo</p>
          </div>
          <div class="column has-text-centered">
            <p class="title is-4 mb-1">40+</p>
            <p class="is-size-7">Anos de história</p>
          </div>
          <div class="column has-text-centered">
            <p class="title is-4 mb-1">12k</p>
            <p class="is-size-7">Visitantes/ano</p>
          </div>
        </div>
      </div>
      <div class="column is-5-desktop">
        <figure class="image is-4by3 rounded-img">
          <img
            src="/public/img/museu-destaque.jpg"
            alt="Fotografia antiga em preto e branco de trabalhadores colhendo uvas em um vinhedo"
            loading="lazy"
          />
        </figure>
      </div>
    </div>
  </div>
</section>

<section id="destaques" class="section has-background-light">
  <div class="container">
    <p class="is-size-7 has-text-weight-semibold has-text-grey mb-2">EXPLORE</p>
    <h2 class="title is-3">O que você encontra aqui</h2>
    <div class="columns is-multiline mt-4">
      <div class="column is-6-desktop">
        <article class="card">
          <div class="card-image">
            <div class="has-background-grey-lighter p-6 has-text-centered has-text-grey">Imagem do Acervo</div>
          </div>
          <div class="card-content">
            <span class="tag is-danger is-light mb-3">Acervo</span>
            <h3 class="title is-4">Peças e Coleções</h3>
            <p>
              Ferramentas vinícolas, toneis históricos, fotos e documentos que testemunham a trajetória da uva ao vinho
              na região.
            </p>
            <a href="/acervo" class="button mt-4 acervo-cta-link">Explorar acervo</a>
          </div>
        </article>
      </div>

      <div class="column is-6-desktop">
        <article class="card">
          <div class="card-image">
            <div class="has-background-grey-lighter p-6 has-text-centered has-text-grey">Imagem das Exposições</div>
          </div>
          <div class="card-content">
            <span class="tag is-warning is-light mb-3">Exposições</span>
            <h3 class="title is-4">Mostras e Galerias</h3>
            <p>
              Exposições temporárias e permanentes que contextualizam a vitivinicultura no cenário cultural e histórico
              regional.
            </p>
            <a href="#timeline" class="button is-outlined mt-4">Ver linha do tempo</a>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<section class="section" id="timeline">
  <div class="container">
    <p class="is-size-7 has-text-weight-semibold has-text-grey mb-2">HISTÓRIA</p>
    <h2 class="title is-3">Uma linha do tempo da vitivinicultura</h2>
    <p class="mb-5">Da chegada dos imigrantes italianos ao reconhecimento do vinho catarinense.</p>

    <div class="columns is-multiline">
      <div class="column is-6-tablet is-3-desktop">
        <div class="box">
          <p class="tag is-dark mb-2">1875</p>
          <p>Chegada dos primeiros imigrantes italianos ao Vale do Rio do Peixe.</p>
        </div>
      </div>
      <div class="column is-6-tablet is-3-desktop">
        <div class="box">
          <p class="tag is-dark mb-2">1910</p>
          <p>Primeiros vinhedos comerciais instalados na região de Videira.</p>
        </div>
      </div>
      <div class="column is-6-tablet is-3-desktop">
        <div class="box timeline-highlight-card">
          <p class="tag timeline-highlight-year mb-2">1984</p>
          <p class="timeline-highlight-text">Fundação do Museu do Vinho de Videira.</p>
        </div>
      </div>
      <div class="column is-6-tablet is-3-desktop">
        <div class="box">
          <p class="tag is-dark mb-2">2003 e Hoje</p>
          <p>Expansão do espaço físico e consolidação como referência turística em SC.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section has-background-dark" id="contato-link">
  <div class="container">
    <div class="columns is-variable is-6">
      <div class="column is-5-desktop">
        <div class="box has-background-dark has-text-white-ter">
          <p class="is-size-7 has-text-weight-semibold has-text-grey-light mb-2">VENHA NOS VISITAR</p>
          <h2 class="title is-3 has-text-white">Planeje sua visita ao Museu</h2>
          <p>Aberto de terça a domingo, das 9h às 17h. Entrada gratuita para escolas e grupos agendados.</p>
          <hr class="has-background-grey-dark" />
          <p><strong class="has-text-white">Endereço:</strong> Rua Padre Anchieta n° 334, Matriz, Videira, SC</p>
          <div>
            <p><strong class="has-text-white">Atendimento:</strong></p>
            <p class="is-size-7">Terça a Sexta: 08h00 - 12h00 | 13h00 - 17h00.</p>
            <p class="is-size-7">Sábado e Domingo: 14h00 - 17h30.</p>
            <p class="is-size-7">Segunda-feira: Fechado.</p>
          </div>
          <p><strong class="has-text-white">Contato:</strong> (49) 3566-6133 · museudovinho@videira.sc.gov.br</p>
          <div class="buttons mt-4">
            <a class="button is-warning" href="https://wa.me/5549991561089" target="_blank" rel="noopener noreferrer"
              >Agendar visita</a
            >
            <a class="button is-light is-outlined" href="mailto:museudovinho@videira.sc.gov.br">Fale conosco</a>
          </div>
        </div>
      </div>

      <div class="column is-7-desktop">
        <div class="box has-background-dark">
          <div id="museum-map" class="contact-map" aria-label="Mapa com a localização do Museu do Vinho"></div>
          <div
            class="is-flex is-justify-content-space-between is-align-items-center mt-3 is-flex-wrap-wrap"
            style="gap: 0.75rem"
          >
            <p class="has-text-grey-light is-size-7">Mapa interativo com Leaflet e OpenStreetMap · Videira, SC</p>
            <a
              class="button is-light is-outlined is-small"
              href="https://www.google.com/maps/search/?api=1&query=-27.0083,-51.1518"
              target="_blank"
              rel="noopener noreferrer"
              >Abrir no Google Maps</a
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{{/base}}
