{{#> base pageTitle=pageTitle year=year themeColor="#7b1c2e" isHome=true loadLeaflet=true}}
<section id="home" class="hero is-medium is-dark home-hero-highlight">
  <div class="hero-body">
    <div class="container">
      <p class="tag is-warning is-light mb-4">Videira - Santa Catarina - Est. 1984</p>
      <h1 class="title is-1">A memória viva do vinho catarinense</h1>
      <p class="subtitle is-5">
        Um espaço dedicado à história, cultura e tradição vinícola do Vale do Rio do Peixe. Descubra anos de imigração
        italiana e paixão pela viticultura.
      </p>
      <p class="hero-museum-signature">Museu do Vinho <span class="hero-museum-name">Mario de Pellegrin</span></p>
      <div class="buttons mt-5">
        <a href="/acervo" class="button is-medium has-text-weight-semibold acervo-cta-link">Explorar acervo</a>
        <a href="#destaques" class="button is-light is-medium">Ver destaques</a>
      </div>
    </div>
  </div>
</section>

<section class="section" id="institucional">
  <div class="container">
    <div class="columns is-vcentered is-variable is-6">
      <div class="column is-7-desktop">
        <p class="is-size-7 has-text-weight-semibold has-text-grey mb-2">O MUSEU</p>
        <h2 class="title is-2">Guardiões da cultura vinícola do Sul do Brasil</h2>
        <p>
          Fundado na cidade de Videira, o Museu do Vinho preserva e difunde o patrimônio histórico e cultural ligado à
          vitivinicultura regional.
        </p>
        <p class="mt-3">
          O acervo reúne ferramentas, documentos, fotografias e objetos que contam a saga dos colonizadores italianos na
          região.
        </p>
        <div class="columns is-mobile mt-4">
          <div class="column has-text-centered">
            <p class="title is-4 mb-1">2400+</p>
            <p class="is-size-7">Peças no acervo</p>
          </div>
          <div class="column has-text-centered">
            <p class="title is-4 mb-1">40+</p>
            <p class="is-size-7">Anos de história</p>
          </div>
          <div class="column has-text-centered">
            <p class="title is-4 mb-1">12k</p>
            <p class="is-size-7">Visitantes/ano</p>
          </div>
        </div>
      </div>
      <div class="column is-5-desktop">
        <figure class="image is-4by3 rounded-img">
          <img
            src="/public/img/museu-destaque.jpg"
            alt="Fotografia antiga em preto e branco de trabalhadores colhendo uvas em um vinhedo"
            loading="lazy"
          />
        </figure>
      </div>
    </div>
  </div>
</section>

<section id="destaques" class="section has-background-light">
  <div class="container">
    <p class="is-size-7 has-text-weight-semibold has-text-grey mb-2">EXPLORE</p>
    <h2 class="title is-3">O que você encontra aqui</h2>
    <div class="columns is-multiline mt-4">
      <div class="column is-6-desktop">
        <article class="card">
          <div class="card-image">
            {{!--
            <div class="has-background-grey-lighter p-6 has-text-centered has-text-grey">Imagem do Acervo</div>
            --}}
            <img
              src="public/img/museu-acervo-destaque.webp"
              alt="Fotografia de uma parte do acervo do museu com objetos expostos em prateleiras e paredes"
              loading="lazy"
            />
          </div>
          <div class="card-content">
            <span class="tag is-danger is-light mb-3">Acervo</span>
            <h3 class="title is-4">Peças e Coleções</h3>
            <p>
              Ferramentas vinícolas, toneis históricos, fotos e documentos que testemunham a trajetória da uva ao vinho
              na região.
            </p>
            <a href="/acervo" class="button mt-4 acervo-cta-link">Explorar acervo</a>
          </div>
        </article>
      </div>

      <div class="column is-6-desktop">
        <article class="card">
          <div class="card-image">
            <img
              src="public/img/museu-exposicoes.webp"
              alt="Fotografia de uma exposição do museu com objetos em vitrines e painéis explicativos"
              loading="lazy"
            />
          </div>
          <div class="card-content">
            <span class="tag is-warning is-light mb-3">Exposições</span>
            <h3 class="title is-4">Mostras e Galerias</h3>
            <p>
              Exposições temporárias e permanentes que contextualizam a vitivinicultura no cenário cultural e histórico
              regional.
            </p>
            <a href="#timeline" class="button is-outlined mt-4">Ver linha do tempo</a>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

