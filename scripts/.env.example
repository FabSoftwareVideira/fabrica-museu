# -------------------------------------------------------------------
# Configurações do gerador de thumbnails
# Copie este arquivo para scripts/.env e ajuste os valores.
# -------------------------------------------------------------------

# Caminho relativo ao volume montado no container (/workspace)
# em que está o JSON do acervo.
ARQUIVO_JSON=src/data/acervo-index.json

# Pasta raiz do projeto (onde ficam as subpastas public/photos, etc.)
# Relativo ao volume montado (/workspace).
PASTA_RAIZ=src/public

# Pasta de destino das thumbnails (será criada se não existir).
PASTA_THUMBS=src/public

# Largura máxima em pixels das thumbnails geradas.
LARGURA_THUMB=250

# 1 = regerar thumbnails existentes
# 0 = pular geração de thumbs que já existem
REGERAR_EXISTENTES=0

# 1 = usar JSON do acervo como fonte (recomendado)
# 0 = varredura direta da pasta photos (fallback)
USAR_JSON=1

# Caminho do arquivo de log com erros de geração de thumbs.
# Relativo ao volume montado (/workspace).
ARQUIVO_LOG_ERROS=logs/thumbs-erros.log
