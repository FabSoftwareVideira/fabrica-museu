{
    "$schema": "https://json.schemastore.org/prettierrc",
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 2,
    "overrides": [
        {
            "files": "*.hbs",
            "options": {
                "parser": "html",
                "singleQuote": false,
                "printWidth": 120
            }
        }
    ]
}