<%- include('partials/head') %>
<%- include('partials/header') %>

    <main>
        <section class="hero-premium">
            <div class="faixa-topo">
                <div class="container">
                    PÁGINA 1 — PÁGINA INICIAL
                </div>
            </div>
            
            <div class="container">
                <div class="hero-conteudo">
                    <span class="tag-hero">VIDEIRA · SANTA CATARINA · EST. 1984</span>
                    
                    <h1>A memória<br>viva do <em>vinho</em><br>catarinense</h1>
                    
                    <p>Um espaço dedicado à história, cultura e tradição vinícola do Vale do Rio do Peixe. Descubra séculos de imigração italiana e paixão pela viticultura.</p>
                    
                    <div class="hero-botoes">
                        <a href="#acervo" class="btn btn-dourado">Explorar Acervo</a>
                        <a href="#" class="btn btn-contorno">Ver Exposições</a>
                    </div>
                </div>
            </div>
        </section>

        <section id="acervo" class="acervo-secao">
            <div class="container">
                <div class="acervo-cabecalho">
                    <h2>Nosso Acervo</h2>
                    <p>Conheça algumas das peças que preservam a nossa tradição.</p>
                </div>

                <div class="acervo-grid">
                    <div class="acervo-card">
                        <h3>Prensas Antigas</h3>
                        <p>Equipamentos utilizados pelos primeiros colonos na extração do mosto da uva.</p>
                    </div>
                    <div class="acervo-card">
                        <h3>Documentos Históricos</h3>
                        <p>Registros e fotografias que documentam a evolução da vitivinicultura em Videira.</p>
                    </div>
                    <div class="acervo-card">
                        <h3>Garrafas Raras</h3>
                        <p>Uma coleção de garrafas e rótulos que marcaram as primeiras colheitas da região.</p>
                    </div>
                    <div class="acervo-card">
                        <h3>Ferramentas de Tanoaria</h3>
                        <p>A arte da construção dos barris de madeira explicada através das ferramentas originais.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="contato" class="contato-secao">
            <div class="container">
                <div class="contato-conteudo">
                    <h2>Visite o Museu</h2>
                    <p>Venha conhecer a nossa história de perto. Estamos de portas abertas para você e sua família.</p>
                    
                    <div class="contato-info">
                        <p><strong>Endereço:</strong> Rua Padre Anchieta, 344 - Centro, Videira - SC</p>
                        <p><strong>Horário:</strong> Terça a domingo, das 9h às 17h</p>
                    </div>

                    <a href="#" target="_blank" class="btn-contato">Fale conosco no WhatsApp</a>
                </div>
            </div>
        </section>

    </main>

<%- include('partials/footer') %>